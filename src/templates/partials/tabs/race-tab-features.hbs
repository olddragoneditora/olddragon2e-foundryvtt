<div class="race-tab-features">
    {{!-- Características --}}
    <div class="features">
        {{!-- Movimento --}}
        <div class="movement">
            <label class="font-bold">{{localize "olddragon2e.mv"}}</label>
            <input name="system.movement" type="text" value="{{system.movement}}" data-dtype="Number">
        </div>
        {{!-- Movimento - Nadar --}}
        <div class="movement-swim">
            <label class="font-bold">{{localize "olddragon2e.mv"}} - {{localize "olddragon2e.mv_swim"}}</label>
            <input name="system.movement_swim" type="text" value="{{system.movement_swim}}" data-dtype="Number">
        </div>
        {{!-- Movimento - Voar --}}
        <div class="movement-fly">
            <label class="font-bold">{{localize "olddragon2e.mv"}} - {{localize "olddragon2e.mv_fly"}}</label>
            <input name="system.movement_fly" type="text" value="{{system.movement_fly}}" data-dtype="Number">
        </div>
        {{!-- Movimento - Observações --}}
        <div class="movement-notes">
            <label class="font-bold">{{localize "olddragon2e.movement_notes"}}</label>
            <input name="system.movement_notes" type="text" value="{{system.movement_notes}}">
        </div>
        {{!-- Infravisão --}}
        <div class="infravision">
            <label class="font-bold">{{localize "olddragon2e.infravision"}}</label>
            <input name="system.infravision" type="text" value="{{system.infravision}}" data-dtype="Number">
        </div>
        {{!-- Infravisão - Observações --}}
        <div class="infravision-notes">
            <label class="font-bold">{{localize "olddragon2e.infravision_notes"}}</label>
            <input name="system.infravision_notes" type="text" value="{{system.infravision_notes}}">
        </div>
        {{!-- Tendência de Alinhamento --}}
        <div class="alignment-tendency">
            <label class="font-bold">{{localize "olddragon2e.alignment_tendency"}}</label>
            <select name="system.alignment_tendency">
                {{selectOptions config.alignment_tendency selected=system.alignment_tendency localize=true}}
            </select>
        </div>        
    </div>
</div>